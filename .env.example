# sqlserver-semantic-mcp — Environment Configuration
# Copy this file to .env and fill in the required values.
# All variables use the SEMANTIC_MCP_ prefix.
# The .env file is loaded automatically from the process working directory.
#
# Required: MSSQL_SERVER, MSSQL_DATABASE, and either (MSSQL_USER + MSSQL_PASSWORD) or MSSQL_WINDOWS_AUTH=true

# --- Connection (required) ---
SEMANTIC_MCP_MSSQL_SERVER=localhost          # hostname, IP, named instance, or Azure FQDN
SEMANTIC_MCP_MSSQL_DATABASE=YourDatabase    # target database name
SEMANTIC_MCP_MSSQL_USER=sa                  # SQL auth user — omit if using Windows auth
SEMANTIC_MCP_MSSQL_PASSWORD=YourStrongPassword  # SQL auth password — omit if using Windows auth

# --- Connection (optional) ---
# SEMANTIC_MCP_MSSQL_PORT=1433              # override default TCP port
# SEMANTIC_MCP_MSSQL_WINDOWS_AUTH=false     # set true to use Windows auth (Windows only; omit USER/PASSWORD above)
# SEMANTIC_MCP_MSSQL_ENCRYPT=false          # force TLS — auto-enabled when server ends in .database.windows.net

# --- Cache and startup ---
# SEMANTIC_MCP_CACHE_PATH=./cache/semantic_mcp.db   # SQLite cache location; use absolute path for multi-instance setups
# SEMANTIC_MCP_CACHE_ENABLED=true                   # set false to disable cache (forces schema queries on every tool call)
# SEMANTIC_MCP_STARTUP_MODE=cache_first             # cache_first: reuse existing cache on restart | full: always refresh from SQL Server
# SEMANTIC_MCP_BACKGROUND_BATCH_SIZE=5              # tables analysed per background batch (tune for large schemas)
# SEMANTIC_MCP_BACKGROUND_INTERVAL_MS=500           # milliseconds between background batches

# --- Policy ---
# SEMANTIC_MCP_POLICY_FILE=./config/policy.example.json   # path to JSON policy file; builtin read-only used if unset
# SEMANTIC_MCP_POLICY_PROFILE=readonly                     # override the active_profile defined in the policy file
# SEMANTIC_MCP_MAX_ROWS_RETURNED=1000                      # SELECT result row cap
# SEMANTIC_MCP_MAX_ROWS_AFFECTED=100                       # DML affected-row cap (rolled back if exceeded when STRICT_ROWS_AFFECTED_CAP=true)
# SEMANTIC_MCP_QUERY_TIMEOUT=30                            # per-query timeout in seconds

# --- Tool surface ---
# SEMANTIC_MCP_TOOL_PROFILE=all
# SEMANTIC_MCP_WORKFLOW_TOOLS_ENABLED=true
# SEMANTIC_MCP_DIRECT_EXECUTE_ENABLED=true
# SEMANTIC_MCP_STRICT_ROWS_AFFECTED_CAP=true

# --- Agent-oriented defaults ---
# SEMANTIC_MCP_DEFAULT_DETAIL=brief
# SEMANTIC_MCP_DEFAULT_RESPONSE_MODE=summary
# SEMANTIC_MCP_DEFAULT_TOKEN_BUDGET_HINT=low

# --- Metrics and analysis ---
# SEMANTIC_MCP_METRICS_ENABLED=true
# SEMANTIC_MCP_INTENT_ANALYZER=regex

# --- Common scenarios (uncomment the relevant block) ---
#
# Windows Authentication (Windows only):
#   SEMANTIC_MCP_MSSQL_SERVER=MY-PC\\SQLEXPRESS
#   SEMANTIC_MCP_MSSQL_WINDOWS_AUTH=true
#   (remove MSSQL_USER and MSSQL_PASSWORD above)
#
# Azure SQL:
#   SEMANTIC_MCP_MSSQL_SERVER=yourserver.database.windows.net
#   SEMANTIC_MCP_MSSQL_USER=youradmin@yourserver
#   (MSSQL_ENCRYPT is enabled automatically for Azure SQL)
#
# LocalDB (Windows only):
#   SEMANTIC_MCP_MSSQL_SERVER=(localdb)\MSSQLLocalDB
#   SEMANTIC_MCP_MSSQL_WINDOWS_AUTH=true
#
# Custom policy (read-write with row caps):
#   SEMANTIC_MCP_POLICY_FILE=./config/policy.example.json
#   SEMANTIC_MCP_POLICY_PROFILE=read_write_safe
